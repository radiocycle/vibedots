sort=-time
layer=overlay
background-color={{colors.surface_container_high.default.hex}}ee
width=340
height=110
border-size=2
border-color={{colors.primary.default.hex}}cc
border-radius=10
icons=1
max-icon-size=48
default-timeout=4000
ignore-timeout=0
font=JetBrainsMono Nerd Font Mono 12
text-color={{colors.on_surface.default.hex}}
padding=12

[urgency=low]
background-color={{colors.surface_container.default.hex}}dd
border-color={{colors.outline.default.hex}}88
text-color={{colors.on_surface_variant.default.hex}}

[urgency=normal]
background-color={{colors.surface_container_high.default.hex}}ee
border-color={{colors.primary.default.hex}}cc
text-color={{colors.on_surface.default.hex}}

[urgency=high]
background-color={{colors.error_container.default.hex}}ee
border-color={{colors.error.default.hex}}
text-color={{colors.on_error_container.default.hex}}
